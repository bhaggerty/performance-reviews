# Slack (from your Slack app settings)
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-   # Socket Mode optional; use if not exposing HTTP

# App URL (for OAuth / redirects if needed; ECS task URL or ALB)
APP_URL=https://your-app.example.com

# AWS (use IAM role on ECS; or keys for local dev)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# DynamoDB table name (single table)
DYNAMODB_TABLE=performance-reviews

# S3 bucket for documents
S3_BUCKET=performance-reviews-docs
S3_PREFIX=Performance Reviews

# Optional private archive webhook (for Google Drive / Apps Script or another document system)
DOCUMENT_ARCHIVE_WEBHOOK_URL=
DOCUMENT_ARCHIVE_WEBHOOK_SECRET=

# Optional AI follow-up coach for sparse review submissions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_MS=1800

# Optional: Socket Mode (set to true to run without public URL)
USE_SOCKET_MODE=false
